{
  "name": "arkm",
  "version": "1.0.0",
  "description": "ArkM 明日方舟音乐下载播放系统",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.arkm.app",
    "productName": "ArkM",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**",
      "assets/**",
      "backend/**"
    ],
    "extraResources": [
      { "from": "../ArkM__/src", "to": "backend" }
    ],
    "win": {
      "icon": "assets/prts.ico"
    }
  },
  "devDependencies": {
    "electron": "^30.0.0"
  }
}
