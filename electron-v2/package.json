{
  "name": "arkm",
  "version": "1.0.0",
  "description": "ArkM 明日方舟音乐下载播放系统",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.arkm.app",
    "productName": "ArkM",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**",
      "assets/**"
    ],
    "extraResources": [
      {
        "from": "../ArkM__/dist/ark-backend",
        "to": "ark-backend"
      }
    ],
    "win": {
      "icon": "assets/prts.ico",
      "target": "portable"
    }
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^26.8.1"
  }
}
